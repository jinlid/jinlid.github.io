function formatSize(size) { 
		var k,u;
		if(size>1e9) { k = 1e-7; u = 'G';
		} else if (size>1e6) { k = 1e-4; u = 'M';
		} else if (size>1e3) { k = 0.1; u = 'k';
		} else {   
			return size + 'b';
		}		
		size = 0.01 * parseInt(size * k);
		return ('' + size).replace(/(\.\d\d)\d+$/, "$1") + u + 'b';
}
